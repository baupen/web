{% extends "_base.html.twig" %}

{% block title %}{{ "resolve.title"|trans }}{% endblock %}
{% block description %}{{ "resolve.description"|trans }}{% endblock %}

{% trans_default_domain "public" %}

{% block layout %}
    <div class="container-fluid p-2 p-md-3 p-xl-4">
        <p class="lead mb-4">{{ block("description") }}</p>

        <script src="{{ url('public_resolve_shared_js', {"token": token}) }}"></script>
        <div id="resolve">
        </div>
    </div>
{% endblock %}
